ni# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-
OPENROUTER_LLM_MODEL=anthropic/claude-sonnet-20241022
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_documents

# PostgreSQL
DATABASE_URL=postgresql+psycopg://rag_user:rag_pass@localhost:5432/rag

# RAG
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
USE_RERANKER=false
